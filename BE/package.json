{
  "name": "ecommerce-be",
  "version": "1.0.0",
  "private": true,
  "description": "E-commerce API (Express, MongoDB, Mongoose)",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "nodemon --watch src --watch server.ts --ext ts --exec tsx server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed": "tsx scripts/seed.ts",
    "seed:reset": "tsx scripts/seed.ts --reset",
    "migrate:up": "tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js up -f migrate-mongo-config.ts",
    "migrate:down": "tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js down -f migrate-mongo-config.ts",
    "migrate:status": "tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js status -f migrate-mongo-config.ts",
    "migrate:create": "tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js create -f migrate-mongo-config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.7",
    "migrate-mongo": "^14.0.7",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
