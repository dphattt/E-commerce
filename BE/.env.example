# Server
PORT=3001
NODE_ENV=development

# MongoDB (base URL without trailing slash; database name separate)
MONGODB_URL=mongodb://127.0.0.1:27017
MONGODB_DATABASE=e-commerce

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
# Optional: distinct secret for refresh tokens. Falls back to JWT_SECRET.
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
# Short-lived access token TTL (used as Authorization: Bearer).
JWT_ACCESS_EXPIRES_IN=15m
# Long-lived refresh token TTL (httpOnly cookie).
JWT_REFRESH_EXPIRES_IN=7d
# Legacy: kept so old configs still parse, but new code reads
# JWT_ACCESS_EXPIRES_IN first.
JWT_EXPIRES_IN=15m

# CORS (comma-separated origins, or * for any)
CORS_ORIGIN=http://localhost:3000
