FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM deps AS builder
WORKDIR /app
COPY . .
RUN mkdir -p public

ARG NEXT_PUBLIC_BASE_API=http://localhost:3001/api
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID=
ARG NEXT_PUBLIC_ADMIN_DASHBOARD_URL=http://localhost:3000/admin
ARG NEXT_PUBLIC_HOME_BRATZ_HERO_VIDEO_DESKTOP_URL=
ARG NEXT_PUBLIC_HOME_BRATZ_HERO_VIDEO_MOBILE_URL=
ARG NEXT_PUBLIC_HOME_BRATZ_HERO_POSTER_URL=
ARG NEXT_PUBLIC_HOME_PREMIUM_HERO_VIDEO_DESKTOP_URL=
ARG NEXT_PUBLIC_HOME_PREMIUM_HERO_VIDEO_MOBILE_URL=
ARG NEXT_PUBLIC_HOME_PREMIUM_HERO_POSTER_URL=

ENV NEXT_PUBLIC_BASE_API=$NEXT_PUBLIC_BASE_API
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID
ENV NEXT_PUBLIC_ADMIN_DASHBOARD_URL=$NEXT_PUBLIC_ADMIN_DASHBOARD_URL
ENV NEXT_PUBLIC_HOME_BRATZ_HERO_VIDEO_DESKTOP_URL=$NEXT_PUBLIC_HOME_BRATZ_HERO_VIDEO_DESKTOP_URL
ENV NEXT_PUBLIC_HOME_BRATZ_HERO_VIDEO_MOBILE_URL=$NEXT_PUBLIC_HOME_BRATZ_HERO_VIDEO_MOBILE_URL
ENV NEXT_PUBLIC_HOME_BRATZ_HERO_POSTER_URL=$NEXT_PUBLIC_HOME_BRATZ_HERO_POSTER_URL
ENV NEXT_PUBLIC_HOME_PREMIUM_HERO_VIDEO_DESKTOP_URL=$NEXT_PUBLIC_HOME_PREMIUM_HERO_VIDEO_DESKTOP_URL
ENV NEXT_PUBLIC_HOME_PREMIUM_HERO_VIDEO_MOBILE_URL=$NEXT_PUBLIC_HOME_PREMIUM_HERO_VIDEO_MOBILE_URL
ENV NEXT_PUBLIC_HOME_PREMIUM_HERO_POSTER_URL=$NEXT_PUBLIC_HOME_PREMIUM_HERO_POSTER_URL

RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000
CMD ["node", "server.js"]
