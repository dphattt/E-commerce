# Copy to .env in repo root for docker compose:
#   cp .env.docker.example .env

# MongoDB (docker internal auth)
MONGO_USER=admin
MONGO_PASSWORD=supersecret123
MONGODB_DATABASE=e-commerce

# Backend
JWT_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
CORS_ORIGIN=http://localhost:3000
APP_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:3001
GOOGLE_CLIENT_ID=

# Frontend (NEXT_PUBLIC_* are baked in at image build time)
NEXT_PUBLIC_BASE_API=http://localhost:3001/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_ADMIN_DASHBOARD_URL=http://localhost:3000/admin
NEXT_PUBLIC_HOME_BRATZ_HERO_VIDEO_DESKTOP_URL=https://res.cloudinary.com/dlbc6kvrf/video/upload/v1781019859/BRATZ_DESKTOP_V2_1_lqo0ls.mp4
NEXT_PUBLIC_HOME_BRATZ_HERO_VIDEO_MOBILE_URL=https://res.cloudinary.com/dlbc6kvrf/video/upload/v1781019859/BRATZ_DESKTOP_V2_1_lqo0ls.mp4
NEXT_PUBLIC_HOME_BRATZ_HERO_POSTER_URL=https://res.cloudinary.com/dlbc6kvrf/video/upload/so_1/v1781019859/BRATZ_DESKTOP_V2_1_lqo0ls.jpg
NEXT_PUBLIC_HOME_PREMIUM_HERO_VIDEO_DESKTOP_URL=https://res.cloudinary.com/dlbc6kvrf/video/upload/v1781019855/GSLC_8x3_WEB_BANNER_e45rub.mp4
NEXT_PUBLIC_HOME_PREMIUM_HERO_VIDEO_MOBILE_URL=https://res.cloudinary.com/dlbc6kvrf/video/upload/v1781019855/GSLC_8x3_WEB_BANNER_e45rub.mp4
NEXT_PUBLIC_HOME_PREMIUM_HERO_POSTER_URL=https://res.cloudinary.com/dlbc6kvrf/video/upload/so_1/v1781019855/GSLC_8x3_WEB_BANNER_e45rub.jpg

